<div id="task_card_<%= task.id %>" class="card h-100 task-card <%= 'opacity-50' if task.completed? %>">
  <div class="card-body d-flex flex-column">
    <div class="d-flex justify-content-between align-items-center mb-3 gap-2">
      <%= turbo_frame_tag "task_state_btn_#{task.id}" do %>
        <% if task.completed? %>
          <%= button_to task, method: :patch, params: { task: { task_state_id: TaskState.todo.id } }, class: "btn btn-link p-0 border-0 task-state-btn" do %>
            <i class="far fa-check-circle" style="color: <%= task.state.color %>;"></i>
          <% end %>
        <% else %>
          <%= button_to task, method: :patch, params: { task: { task_state_id: TaskState.done.id } }, class: "btn btn-link p-0 border-0 task-state-btn" do %>
            <i class="far fa-dot-circle" style="color: <%= task.state.color %>;"></i>
          <% end %>
        <% end %>
      <% end %>
      <% unless task.completed? %>
        <% if task.overdue? %>
          <p class="task-deadline task-deadline-overdue">期限切れです！</p>
        <% else %>
          <p class="task-deadline task-deadline-ongoing"><%= days_to_deadline_as_string task %></p>
        <% end %>
      <% end %>
      <small class="text-muted task-creator-badge">
        <i class="bi bi-person-fill"></i>
        <%= link_to task.assigner.name, task.assigner, class: "text-muted text-decoration-none" %>
      </small>
    </div>

    <div class="mt-auto">
      <h5 class="card-title mb-3">
        <%= link_to task.content.truncate(30), task, class: "text-black text-decoration-none card-link" %>
      </h5>

      <div class="task-date-row mb-2 d-flex justify-content-between align-items-center gap-2">
        <div>
          <% if task.project %>
            <%= link_to task.project.name, task.project, class: "task-project-badge" %>
          <% end %>
        </div>
        <div class="task-tag-list">
          <% task.tags.each do |tag| %>
            <%= link_to tag.name, tag, class: "task-tag-badge" %>
          <% end %>
        </div>
        <small class="text-muted"><%= task.show_days_ago.round.to_s + "日前" %></small>
      </div>
    </div>
  </div>
</div>
